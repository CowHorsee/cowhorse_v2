                  },
                  "status_name": {
                    "type": "string",
                    "enum": [
                      "Awaiting Warehouse",
                      "Shipped",
                      "Delivered"
                    ],
                    "description": "Target status name"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/warehouse/count_inventory": {
      "get": {
        "summary": "Count inventory",
        "description": "Retrieves the current stock level for a specific item or all items from the warehouse stock table.",
        "operationId": "get_api_count_inventory",
        "tags": [
          "Warehouse"
        ],
        "responses": {
          "200": {
            "description": "Stock levels retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "integer",
