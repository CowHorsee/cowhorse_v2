          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "user_id",
                  "pr_id",
                  "proc_item",
                  "justification"
                ],
                "properties": {
                  "user_id": {
                    "type": "string",
                    "format": "uuid",
