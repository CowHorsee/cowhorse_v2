                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Data migration complete"
                    },
                    "details": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "string"
                      },
                      "description": "Row counts per table",
                      "example": {
                        "user": "Loaded 50 rows.",
                        "item": "Loaded 200 rows."
                      }
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Failed to load datasets or connection string missing"
          }
        }
      }
    },
