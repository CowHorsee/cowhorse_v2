    "/api/po/update_po_status": {
      "post": {
        "summary": "Update PO status",
        "description": "Allows a Supplier to update the status of an order (e.g., 'Awaiting Warehouse', 'Shipped'). Rules vary by current status.",
        "operationId": "post_api_update_po_status",
        "tags": [
          "Purchase Order"
        ],
        "responses": {
          "200": {
            "description": "PO status successfully transitioned"
          },
          "400": {
            "description": "Invalid status transition or unauthorized supplier"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "supplier_id",
                  "po_id",
                  "status_name"
                ],
                "properties": {
                  "supplier_id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "ID of the supplier performing the update"
                  },
                  "po_id": {
                    "type": "string",
